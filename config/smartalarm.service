[Unit]
Description=SmartAlarmPi service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/js2042/Documents/projects/SmartAlarmPi/backend
ExecStart=/home/js2042/Documents/projects/SmartAlarmPi/venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 5000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
